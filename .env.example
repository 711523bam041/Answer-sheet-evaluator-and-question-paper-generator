# Root Environment Configuration for Docker Compose

# Backend Settings
SECRET_KEY=use-at-least-32-random-chars-in-production
JWT_SECRET_KEY=use-at-least-32-random-chars-in-production
FLASK_ENV=production
DATABASE_URL=postgresql://evaluator:evaluator123@db:5432/answer_evaluator
LOG_LEVEL=INFO
PLAGIARISM_THRESHOLD=0.80

# PostgreSQL Settings
POSTGRES_DB=answer_evaluator
POSTGRES_USER=evaluator
POSTGRES_PASSWORD=evaluator123

# Frontend Settings
# Note: Since Vite builds during Docker build stage, VITE_API_URL should point to the backend's external API domain
# when deploying to production (e.g. https://api.yourdomain.com). For local docker-compose testing, we fallback 
# to the local backend port mapped on the host.
VITE_API_URL=http://localhost:5000
